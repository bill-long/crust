{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Crust",
  "version": "0.1.0",
  "identifier": "pizza.strange.crust.desktop",
  "build": {
    "devUrl": "http://localhost:5173",
    "frontendDist": "../../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Crust",
        "width": 1200,
        "height": 820,
        "minWidth": 720,
        "minHeight": 480,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
