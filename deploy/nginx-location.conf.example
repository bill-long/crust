# Snippet to add inside the existing `server { listen 443 ... server_name strange.pizza; }`
# block on the host, alongside the existing `/_matrix/`, `/.well-known/matrix/`,
# and `/` locations.
#
# Order matters: place these blocks BEFORE the catch-all `location / {}`
# that proxies to Cinny, so they take precedence for sub-path requests.
#
# Crust is served as static files; the SPA itself does not need a WebSocket
# upgrade through this proxy (Matrix sync streams go directly to the
# homeserver via the existing `/_matrix/` location block).

# Redirect bare /crust -> /crust/ so the SPA loads with the expected base path.
# $is_args$args preserves any query string on the redirect.
location = /crust {
    return 301 /crust/$is_args$args;
}

location /crust/ {
    proxy_pass http://127.0.0.1:8083/;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
}

# ── Optional: background Web Push gateway (Sygnal) ──
# Only needed if you run the `push` compose profile (see deploy/README.md).
#
# This MUST be placed in the same server block as the existing `/_matrix/`
# location that proxies to the homeserver. nginx matches the longest prefix,
# so `/_matrix/push/` takes precedence over `/_matrix/` regardless of order and
# routes the push-gateway notify endpoint to Sygnal instead of the homeserver.
#
# The URL below is what clients register as `push.gatewayUrl` in config.json:
#   https://strange.pizza/_matrix/push/v1/notify
location /_matrix/push/ {
    proxy_pass http://127.0.0.1:8084/_matrix/push/;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
}
