# Example Sygnal push gateway configuration for Crust's background Web Push.
#
# Copy to `sygnal.yaml` on the host next to docker-compose.yml, fill in the
# contact email, and generate the VAPID key (see deploy/README.md). Then start
# the gateway with:  docker compose --profile push up -d
#
# Reference: https://github.com/matrix-org/sygnal/blob/main/docs/applications.md

log:
  setup:
    version: 1
    formatters:
      normal:
        format: "%(asctime)s [%(process)d] %(levelname)-5s %(name)s %(message)s"
    handlers:
      console:
        class: logging.StreamHandler
        formatter: normal
    loggers:
      sygnal:
        level: INFO
    root:
      handlers: [console]
      level: INFO
  access:
    x_forwarded_for: true

http:
  # Listen on all interfaces inside the container; the host binds this to
  # 127.0.0.1:8084 (see docker-compose.yml) and nginx terminates TLS.
  bind_addresses: ["0.0.0.0"]
  port: 5000

metrics:
  prometheus:
    enabled: false
  opentracing:
    enabled: false
  sentry:
    enabled: false

apps:
  # This key is the pusher `app_id`. It MUST exactly match `push.appId` in the
  # Crust config.json that clients load.
  pizza.strange.crust.webpush:
    type: webpush

    # Path (inside the container) to the VAPID private key PEM generated by
    # `vapid --gen --applicationServerKey`. Mounted from ./vapid on the host.
    vapid_private_key: /vapid/private_key.pem

    # Operator contact, embedded in the VAPID JWT `sub` claim. Required.
    vapid_contact_email: admin@strange.pizza

    # Restrict which push-service domains Sygnal will contact. Strongly
    # recommended in production to prevent Sygnal making requests to arbitrary
    # hosts. Matched against the endpoint domain only.
    allowed_endpoints:
      - "updates.push.services.mozilla.com" # Firefox
      - "fcm.googleapis.com" # Chrome / Chromium
      - "*.notify.windows.com" # Edge
      - "web.push.apple.com" # Safari 16+

    # Seconds a push may sit undelivered before the push service drops it.
    ttl: 900
